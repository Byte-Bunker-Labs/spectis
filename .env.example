# Spectis Orchestrator — Environment Variables
# Copy this file to .env and update values for your environment.

# ── Database ──
# PostgreSQL (production):
DATABASE_URL=postgresql+asyncpg://spectis:spectis@localhost:5432/spectis
# SQLite (local development — no setup needed):
# DATABASE_URL=sqlite+aiosqlite:///./spectis.db

# ── JWT Authentication ──
# IMPORTANT: Change this to a random string (min 32 characters) in production
# Generate one with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change-me-to-a-random-secret-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── API Server ──
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info

# ── Audit Logs ──
# Directory for JSONL audit log files (in addition to database)
AUDIT_LOG_DIR=./logs

# ── CORS ──
# Comma-separated origins. Use * for development only.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
